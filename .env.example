# Environment Variables Example
# Copy this file to .env and fill in your actual values

# Google Cloud Project (required if using Secret Manager)
GCP_PROJECT_ID=your-project-id

# --- OPTION 1: Use Environment Variables (Simpler) ---

# Delegated Admin Email (required for group checking)
DELEGATED_ADMIN_EMAIL=admin@yourdomain.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# --- OPTION 2: Use Secret Manager (Production/Secure) ---
# Uncomment these to use Secret Manager instead of env vars above

# DELEGATED_ADMIN_EMAIL_SECRET_NAME=delegated-admin-email
# GOOGLE_CLIENT_ID_SECRET_NAME=google-oauth-client-id
# GOOGLE_CLIENT_SECRET_SECRET_NAME=google-oauth-client-secret

# --- Common Configuration ---

# Redirect URI (adjust for your environment)
REDIRECT_URI=http://localhost:8080/auth/callback
# For Cloud Run: https://your-app-url.run.app/auth/callback

# Service Account Key (for local development only)
# Not needed on Cloud Run where service account is automatic
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
